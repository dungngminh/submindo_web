---
const steps = [
  {
    num: '01',
    icon: '➕',
    title: 'Add Your Subscriptions',
    desc: 'Enter any subscription — name, price, currency, billing cycle, and start date. Supports daily, weekly, monthly, and yearly billing. Set trial periods too.',
  },
  {
    num: '02',
    icon: '🔔',
    title: 'Get Reminded Before Billing',
    desc: "Set custom reminders days before each renewal. Submindo sends push notifications right on time — so you always know what's coming and never get surprised.",
  },
  {
    num: '03',
    icon: '📊',
    title: 'Let AI Analyze Your Spending',
    desc: "Submindo's AI scores your subscription portfolio, detects redundant services, and finds cheaper alternatives — with monthly savings calculations to act on fast.",
  },
];
---

<section class="section hiw-section" id="how-it-works">
  <div class="container">
    <div class="hiw-header">
      <p class="section-eyebrow">Simple by design</p>
      <h2 class="section-title">How Submindo works</h2>
    </div>

    <div class="hiw-grid">
      {steps.map((s, i) => (
        <>
          <div class="hiw-card neo-card">
            <div class="hiw-card-top">
              <span class="hiw-num">{s.num}</span>
              <span class="hiw-icon" aria-hidden="true">{s.icon}</span>
            </div>
            <h3 class="hiw-title">{s.title}</h3>
            <p class="hiw-desc">{s.desc}</p>
          </div>
          {i < steps.length - 1 && (
            <div class="hiw-arrow" aria-hidden="true">
              <span class="hiw-arrow-icon">→</span>
            </div>
          )}
        </>
      ))}
    </div>
  </div>
</section>

<style>
  .hiw-section {
    background: var(--surface);
    border-top: var(--border);
    border-bottom: var(--border);
    content-visibility: auto;
    contain-intrinsic-size: 0 500px;
  }

  .hiw-header {
    text-align: center;
    margin-bottom: var(--sp-12);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    align-items: center;
  }

  .hiw-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    gap: var(--sp-3);
    align-items: stretch;
  }

  .hiw-card {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    transition: transform 100ms, box-shadow 100ms;
  }
  .hiw-card:hover {
    transform: translate(-2px, -2px);
    box-shadow: var(--shadow-lg);
  }

  .hiw-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .hiw-num {
    font-family: var(--font-display);
    font-size: 48px;
    font-weight: 800;
    color: var(--primary);
    line-height: 1;
  }
  .hiw-icon { font-size: 36px; }

  .hiw-title {
    font-family: var(--font-display);
    font-size: var(--text-title1);
    font-weight: 700;
    color: var(--text-primary);
  }
  .hiw-desc {
    font-size: var(--text-body2);
    color: var(--text-secondary);
    line-height: 1.7;
    flex: 1;
  }

  .hiw-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 var(--sp-1);
  }
  .hiw-arrow-icon {
    font-size: 28px;
    font-weight: 700;
    color: var(--primary);
  }

  @media (max-width: 900px) {
    .hiw-grid { grid-template-columns: 1fr; gap: var(--sp-4); }
    .hiw-arrow { padding: 0; }
    .hiw-arrow-icon { display: inline-block; transform: rotate(90deg); font-size: 22px; }
    .hiw-num { font-size: 36px; }
  }
  @media (max-width: 640px) {
    .hiw-header { margin-bottom: var(--sp-6); }
    .hiw-grid { gap: var(--sp-3); }
  }
</style>
