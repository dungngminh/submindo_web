---
const base = import.meta.env.BASE_URL;
---

<section class="hero section" id="home">
  <div class="container">
    <div class="hero-grid">

      <!-- Left: Copy + CTAs -->
      <div class="hero-copy">
        <div class="badge badge-primary" style="margin-bottom: var(--sp-5);">
          🔔 Subscription Tracker + AI
        </div>

        <h1 class="hero-title">
          Stop Losing Money to
          <span class="hero-accent">Forgotten Subscriptions</span>
        </h1>

        <p class="hero-desc">
          Submindo tracks every recurring charge, reminds you before billing dates,
          and uses AI to detect spending waste — and find cheaper alternatives.
        </p>

        <div class="hero-ctas">
          <!-- App Store -->
          <a href="#" class="btn btn-dark btn-lg store-btn" aria-label="Download on App Store">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="white" aria-hidden="true">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.3.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
            <span class="store-btn-text">
              <span class="store-btn-sub">Download on</span>
              <span class="store-btn-name">App Store</span>
            </span>
          </a>

          <!-- Google Play -->
          <a href="#" class="btn btn-outline btn-lg store-btn" aria-label="Get it on Google Play">
            <svg viewBox="0 0 28.99 31.99" width="22" height="22" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
              <path d="M13.54 15.28.12 29.34a3.66 3.66 0 0 0 5.33 2.16l15.1-8.6Z" fill="#ea4335"/>
              <path d="m27.11 12.89-6.53-3.74-7.35 6.45 7.38 7.28 6.48-3.7a3.54 3.54 0 0 0 1.5-4.79 3.62 3.62 0 0 0-1.5-1.5z" fill="#fbbc04"/>
              <path d="M.12 2.66a3.57 3.57 0 0 0-.12.92v24.84a3.57 3.57 0 0 0 .12.92L14 15.64Z" fill="#4285f4"/>
              <path d="m13.64 16 6.94-6.85L5.5.51A3.73 3.73 0 0 0 3.63 0 3.64 3.64 0 0 0 .12 2.65Z" fill="#34a853"/>
            </svg>
            <span class="store-btn-text">
              <span class="store-btn-sub">Get it on</span>
              <span class="store-btn-name">Google Play</span>
            </span>
          </a>
        </div>

        <p class="hero-note">Free to download &nbsp;·&nbsp; iOS &amp; Android</p>
      </div>

      <!-- Right: Visual -->
      <div class="hero-visual" aria-hidden="true">
        <div class="visual-bg"></div>

        <!-- App icon -->
        <div class="app-icon-wrap">
          <img src={`${base}app-icon.png`} alt="Submindo app icon" width="140" height="140" loading="eager" />
        </div>

        <!-- Floating stat cards -->
        <div class="float-card fc-spend neo-card">
          <div class="fc-label">Monthly Spend</div>
          <div class="fc-value">$127.40</div>
          <div class="fc-sub">12 subscriptions tracked</div>
        </div>

        <div class="float-card fc-remind neo-card">
          <div class="fc-remind-row">
            <span class="fc-bell">🔔</span>
            <div>
              <div class="fc-label">Netflix</div>
              <div class="fc-sub" style="color: var(--error);">Billing in 2 days</div>
            </div>
          </div>
        </div>

        <div class="float-card fc-ai neo-card-primary">
          <div class="fc-ai-label">AI Score</div>
          <div class="fc-ai-score">87<span class="fc-ai-denom">/100</span></div>
          <div class="fc-ai-verdict">✅ Worth It</div>
        </div>

        <!-- Decorative corner accents -->
        <div class="corner-accent ca-tl" aria-hidden="true"></div>
        <div class="corner-accent ca-br" aria-hidden="true"></div>
      </div>
    </div>
  </div>
</section>

<!-- Stats bar -->
<div class="stats-bar">
  <div class="container stats-inner">
    <div class="stat-item">
      <span class="stat-num">63+</span>
      <span class="stat-label">Supported Services</span>
    </div>
    <div class="stat-divider" aria-hidden="true"></div>
    <div class="stat-item">
      <span class="stat-num">13</span>
      <span class="stat-label">Spending Categories</span>
    </div>
    <div class="stat-divider" aria-hidden="true"></div>
    <div class="stat-item">
      <span class="stat-num">AI</span>
      <span class="stat-label">Powered Analysis</span>
    </div>
    <div class="stat-divider" aria-hidden="true"></div>
    <div class="stat-item">
      <span class="stat-num">0</span>
      <span class="stat-label">Forgotten Bills</span>
    </div>
  </div>
</div>

<style>
  /* Hero grid */
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-16);
    align-items: center;
    min-height: 520px;
  }

  /* Copy */
  .hero-title {
    font-size: var(--text-display1);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: var(--sp-5);
    letter-spacing: -0.5px;
  }
  .hero-accent {
    color: var(--primary);
    display: block;
  }
  .hero-desc {
    font-size: var(--text-title2);
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: var(--sp-8);
    max-width: 480px;
  }
  .hero-ctas {
    display: flex;
    gap: var(--sp-4);
    flex-wrap: wrap;
    margin-bottom: var(--sp-4);
  }

  /* Store buttons */
  .store-btn {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: 12px var(--sp-5);
  }
  .store-btn-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1px;
  }
  .store-btn-sub {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.3px;
    opacity: 0.8;
    line-height: 1;
  }
  .store-btn-name {
    font-size: 17px;
    font-weight: 700;
    line-height: 1;
  }

  .hero-note {
    font-size: var(--text-body2);
    color: var(--text-secondary);
  }

  /* Visual */
  .hero-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 420px;
  }

  .visual-bg {
    position: absolute;
    inset: 0;
    background: var(--surface);
    border: var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }

  .app-icon-wrap {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .app-icon-wrap img {
    width: 140px;
    height: 140px;
    border-radius: 32px;
    border: var(--border);
    box-shadow: var(--shadow-lg);
    animation: icon-pulse 5s ease-in-out infinite;
  }
  @keyframes icon-pulse {
    0%, 100% { transform: scale(1);    box-shadow: var(--shadow-lg); }
    50%       { transform: scale(1.04); box-shadow: 8px 8px 0 #000; }
  }

  /* Floating cards */
  .float-card {
    position: absolute;
    z-index: 3;
    min-width: 160px;
    padding: var(--sp-4);
  }
  .fc-spend  { top: 16px;    left: -24px;  animation: float-a 4s ease-in-out infinite; }
  .fc-remind { bottom: 60px; left: -24px;  animation: float-b 4.5s ease-in-out infinite; }
  .fc-ai     { top: 24px;    right: -24px; min-width: 130px; animation: float-c 3.8s ease-in-out infinite; }

  @keyframes float-a {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-10px); }
  }
  @keyframes float-b {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-8px); }
  }
  @keyframes float-c {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-12px); }
  }

  .fc-label {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: var(--text-secondary);
    margin-bottom: 4px;
  }
  .fc-value {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1;
  }
  .fc-sub {
    font-size: 11px;
    color: var(--text-secondary);
    margin-top: 4px;
  }
  .fc-remind-row { display: flex; align-items: center; gap: var(--sp-2); }
  .fc-bell { font-size: 20px; }

  .fc-ai-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    opacity: 0.75;
    margin-bottom: 4px;
  }
  .fc-ai-score {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 800;
    line-height: 1;
    color: var(--white);
  }
  .fc-ai-denom { font-size: 18px; opacity: 0.7; }
  .fc-ai-verdict { font-size: 12px; margin-top: 4px; opacity: 0.9; }

  /* Corner accents */
  .corner-accent {
    position: absolute;
    z-index: 1;
    border: var(--border);
    border-radius: 50%;
    pointer-events: none;
  }
  .ca-tl {
    width: 32px; height: 32px;
    background: var(--primary);
    top: 16px; left: 16px;
    box-shadow: 2px 2px 0 #000;
  }
  .ca-br {
    width: 20px; height: 20px;
    background: var(--success);
    bottom: 16px; right: 16px;
    box-shadow: 2px 2px 0 #000;
    animation: dot-ping 2s ease-in-out infinite;
  }
  @keyframes dot-ping {
    0%, 100% { transform: scale(1);    opacity: 1; }
    50%       { transform: scale(1.4); opacity: 0.7; }
  }

  /* Stats bar */
  .stats-bar {
    background: var(--bg);
    border-top: var(--border);
    border-bottom: var(--border);
    padding: var(--sp-5) 0;
  }
  .stats-inner {
    display: flex;
    align-items: center;
    justify-content: space-around;
    gap: var(--sp-6);
  }
  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .stat-num {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 800;
    color: var(--primary);
    line-height: 1;
  }
  .stat-label {
    font-size: var(--text-body2);
    font-weight: 600;
    color: var(--text-secondary);
    white-space: nowrap;
  }
  .stat-divider {
    width: 2px;
    height: 48px;
    background: var(--border-color, #000);
    opacity: 0.15;
    border-radius: 2px;
    flex-shrink: 0;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; gap: var(--sp-8); }
    .hero-visual { min-height: 300px; }
    .fc-spend { top: 12px; left: 0; }
    .fc-remind { bottom: 12px; left: 0; }
    .fc-ai { top: 12px; right: 0; }
    .hero-desc { max-width: 100%; }
  }

  @media (max-width: 640px) {
    .hero-grid { min-height: auto; gap: var(--sp-6); }
    .hero-title { font-size: clamp(26px, 7vw, 36px); }
    .hero-desc { font-size: var(--text-body1); }
    .hero-ctas { gap: var(--sp-3); }
    .store-btn { padding: 10px var(--sp-4); }
    .store-btn-name { font-size: 15px; }
    .stats-inner { gap: var(--sp-4); flex-wrap: wrap; justify-content: center; }
    .stat-num { font-size: 24px; }
    .stat-divider { display: none; }
  }

  @media (max-width: 480px) {
    .fc-spend, .fc-remind, .fc-ai { display: none; }
    .hero-visual { min-height: 200px; }
    .ca-tl, .ca-br { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .fc-spend, .fc-remind, .fc-ai, .app-icon-wrap img, .ca-br {
      animation: none;
    }
  }
</style>
