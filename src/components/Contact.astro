---
import { siteConfig } from '../lib/config';
---

<section class="section contact-section" id="contact">
  <div class="container">
    <div class="contact-inner">
      <div class="contact-copy">
        <p class="section-eyebrow">Get in touch</p>
        <h2 class="section-title">Questions?<br>We're here.</h2>
        <p class="contact-desc">
          Have a feature request, found a bug, or just want to say hi?
          Reach out — we actually read and respond to every message.
        </p>

        <div class="contact-options">
          <a href="mailto:komkat.studio@gmail.com" class="contact-option neo-card">
            <div class="contact-option-icon">✉️</div>
            <div>
              <div class="contact-option-label">Email us</div>
              <div class="contact-option-value">komkat.studio@gmail.com</div>
            </div>
            <div class="contact-option-arrow">→</div>
          </a>
        </div>
      </div>

      <div class="contact-cta-block neo-card">
        <div class="cta-emoji">📲</div>
        <h3 class="cta-title">Ready to take control<br>of your subscriptions?</h3>
        <p class="cta-sub">Download free on iOS and Android. No account required.</p>
        <div class="cta-btns">
          <a href="#" class="btn btn-outline" aria-label="Download on App Store">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="#423F50" aria-hidden="true">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.3.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
            App Store
          </a>
          <a href={siteConfig.googlePlayUrl} class="btn btn-outline" aria-label="Get it on Google Play">
            <svg viewBox="0 0 28.99 31.99" width="18" height="18" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
              <path d="M13.54 15.28.12 29.34a3.66 3.66 0 0 0 5.33 2.16l15.1-8.6Z" fill="#ea4335"/>
              <path d="m27.11 12.89-6.53-3.74-7.35 6.45 7.38 7.28 6.48-3.7a3.54 3.54 0 0 0 1.5-4.79 3.62 3.62 0 0 0-1.5-1.5z" fill="#fbbc04"/>
              <path d="M.12 2.66a3.57 3.57 0 0 0-.12.92v24.84a3.57 3.57 0 0 0 .12.92L14 15.64Z" fill="#4285f4"/>
              <path d="m13.64 16 6.94-6.85L5.5.51A3.73 3.73 0 0 0 3.63 0 3.64 3.64 0 0 0 .12 2.65Z" fill="#34a853"/>
            </svg>
            Google Play
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-10);
    align-items: start;
    padding-right: 8px;
    padding-bottom: 8px;
  }

  .contact-desc {
    font-size: var(--text-body1);
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: var(--sp-8);
  }

  .contact-options { display: flex; flex-direction: column; gap: var(--sp-3); }
  .contact-option {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    text-decoration: none;
    transition: transform 100ms, box-shadow 100ms;
  }
  .contact-option:hover { transform: translate(-2px, -2px); box-shadow: var(--shadow-lg); }
  .contact-option-icon { font-size: 28px; flex-shrink: 0; }
  .contact-option-label {
    font-family: var(--font-display);
    font-size: var(--text-body2);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: var(--text-secondary);
  }
  .contact-option-value {
    font-family: var(--font-display);
    font-size: var(--text-title2);
    font-weight: 700;
    color: var(--text-primary);
  }
  .contact-option-arrow { margin-left: auto; font-size: 24px; color: var(--primary); }

  /* CTA block */
  .contact-cta-block {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-4);
    box-shadow: var(--shadow-lg);
  }
  .cta-emoji { font-size: 48px; }
  .cta-title {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1.2;
  }
  .cta-sub { font-size: var(--text-body2); color: var(--text-secondary); }
  .cta-btns { display: flex; gap: var(--sp-3); flex-wrap: wrap; justify-content: center; margin-top: var(--sp-2); }

  @media (max-width: 768px) {
    .contact-inner { grid-template-columns: 1fr; padding-right: 0; padding-bottom: 8px; }
  }
  @media (max-width: 640px) {
    .cta-emoji { font-size: 36px; }
    .cta-btns { flex-direction: column; width: 100%; }
    .cta-btns .btn { width: 100%; justify-content: center; }
    .contact-option-value { font-size: var(--text-body1); word-break: break-all; }
  }
</style>
