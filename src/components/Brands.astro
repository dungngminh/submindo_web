---
import { fetchBrands, iconToImg } from '../lib/brands';

const base = import.meta.env.BASE_URL;
const b2url = (path: string) => `${base}${path.replace(/^\//, '')}`;

const rawBrands = await fetchBrands();
const withImg = rawBrands
  .filter(b => iconToImg[b.icon])
  .map(b => ({ name: b.name, img: iconToImg[b.icon] }));
const half = Math.ceil(withImg.length / 2);
const row1 = withImg.slice(0, half);
const row2 = withImg.slice(half);
---

<div class="brands-section">
  <p class="brands-label"><span class="count-num" data-target={withImg.length}>0</span>+ services supported out of the box</p>

  <!-- Row 1: scroll left -->
  <div class="brands-track-wrap">
    <div class="brands-track track-left">
      {[...row1, ...row1].map(b => (
        <div class="brand-tile" data-name={b.name}>
          <img src={b2url(b.img)} alt={b.name} width="52" height="52" loading="lazy" decoding="async" class="brand-img" />
        </div>
      ))}
    </div>
  </div>

  <!-- Row 2: scroll right -->
  <div class="brands-track-wrap" style="margin-top: var(--sp-3);">
    <div class="brands-track track-right">
      {[...row2, ...row2].map(b => (
        <div class="brand-tile" data-name={b.name}>
          <img src={b2url(b.img)} alt={b.name} width="52" height="52" loading="lazy" decoding="async" class="brand-img" />
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .brands-section {
    padding: var(--sp-10) 0;
    background: var(--surface);
    border-top: var(--border);
    border-bottom: var(--border);
    overflow: hidden;
  }

  .brands-label {
    text-align: center;
    font-family: var(--font-display);
    font-size: var(--text-body2);
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: var(--sp-6);
    letter-spacing: 0.3px;
  }
  .count-num {
    display: inline-block;
    min-width: 2ch;
    font-variant-numeric: tabular-nums;
    text-align: right;
  }

  .brands-track-wrap { overflow: hidden; padding: 4px 0; }

  .brands-track {
    display: flex;
    gap: var(--sp-3);
    width: max-content;
  }
  .track-left  { animation: scroll-left  45s linear infinite; will-change: transform; }
  .track-right { animation: scroll-right 38s linear infinite; will-change: transform; }
  .brands-track:hover { animation-play-state: paused; }

  @keyframes scroll-left  { from { transform: translateX(0); }    to { transform: translateX(-50%); } }
  @keyframes scroll-right { from { transform: translateX(-50%); } to { transform: translateX(0); } }

  .brand-tile {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    background: #fff;
    border: var(--border);
    border-radius: var(--radius);
    box-shadow: 3px 3px 0 #000;
    flex-shrink: 0;
    cursor: default;
    transition: transform 80ms, box-shadow 80ms;
  }
  .brand-tile:hover {
    transform: translate(-1px, -1px);
    box-shadow: var(--shadow);
  }


.brand-img {
    width: 52px;
    height: 52px;
    object-fit: contain;
    border-radius: 6px;
  }

</style>

<script>
  // Count-up animation
  const countEl = document.querySelector<HTMLElement>('.count-num');
  if (countEl) {
    const target = parseInt(countEl.dataset.target ?? '0', 10);
    const duration = 1400;
    let started = false;

    const easeOut = (t: number) => 1 - Math.pow(1 - t, 3);

    const run = () => {
      if (started) return;
      started = true;
      const start = performance.now();
      const step = (now: number) => {
        const t = Math.min((now - start) / duration, 1);
        countEl.textContent = Math.round(easeOut(t) * target).toString();
        if (t < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    };

    const obs = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) { run(); obs.disconnect(); }
    }, { threshold: 0.3 });
    obs.observe(countEl);
  }

  const tip = document.createElement('div');
  Object.assign(tip.style, {
    position: 'fixed',
    zIndex: '9999',
    background: '#423F50',
    color: '#fff',
    fontFamily: "'Space Grotesk', sans-serif",
    fontSize: '11px',
    fontWeight: '700',
    whiteSpace: 'nowrap',
    padding: '4px 10px',
    borderRadius: '6px',
    border: '1.5px solid #000',
    boxShadow: '2px 2px 0 #000',
    pointerEvents: 'none',
    opacity: '0',
    transition: 'opacity 100ms',
    transform: 'translateX(-50%)',
  });
  document.body.appendChild(tip);

  document.querySelectorAll<HTMLElement>('[data-name]').forEach(tile => {
    tile.addEventListener('mouseenter', () => {
      tip.textContent = tile.dataset.name ?? '';
      const r = tile.getBoundingClientRect();
      tip.style.left = (r.left + r.width / 2) + 'px';
      tip.style.top  = (r.top - 36) + 'px';
      tip.style.opacity = '1';
    });
    tile.addEventListener('mouseleave', () => {
      tip.style.opacity = '0';
    });
  });
</script>
