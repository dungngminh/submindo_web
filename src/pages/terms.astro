---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const effectiveDate = 'May 9, 2026';
---

<Layout
  title="Terms of Service — Submindo"
  description="Terms governing your use of the Submindo subscription tracker app."
>
  <Navbar />
  <main class="legal-page">
    <div class="container">
      <div class="legal-header">
        <a href="/" class="back-link btn btn-surface btn-sm">← Back to Home</a>
        <div class="legal-title-row">
          <h1 class="legal-title">Terms of Service</h1>
          <span class="badge badge-dark">Legal</span>
        </div>
        <p class="legal-meta">Effective Date: <strong>{effectiveDate}</strong> &nbsp;·&nbsp; KomKat Studio</p>
      </div>

      <div class="legal-layout">
        <aside class="legal-toc neo-card-surface">
          <p class="toc-heading">Contents</p>
          <nav>
            <ol class="toc-list">
              <li><a href="#t1">1. Acceptance of Terms</a></li>
              <li><a href="#t2">2. Description of Service</a></li>
              <li><a href="#t3">3. Eligibility</a></li>
              <li><a href="#t4">4. User Content &amp; Data</a></li>
              <li><a href="#t5">5. Acceptable Use</a></li>
              <li><a href="#t6">6. Subscriptions &amp; Payments</a></li>
              <li><a href="#t7">7. Intellectual Property</a></li>
              <li><a href="#t8">8. Disclaimers</a></li>
              <li><a href="#t9">9. Limitation of Liability</a></li>
              <li><a href="#t10">10. Third-Party Services</a></li>
              <li><a href="#t11">11. Termination</a></li>
              <li><a href="#t12">12. Changes to Terms</a></li>
              <li><a href="#t13">13. Governing Law</a></li>
              <li><a href="#t14">14. Contact</a></li>
            </ol>
          </nav>
        </aside>

      <div class="legal-body neo-card">
        <section class="legal-section" id="t1">
          <h2>1. Acceptance of Terms</h2>
          <p>
            By downloading, installing, or using Submindo ("the App"), you agree to be bound by these Terms of Service
            ("Terms"). If you do not agree to these Terms, do not use the App.
          </p>
          <p>
            These Terms apply to all versions of Submindo, including iOS and Android applications, and any
            associated websites (including this landing page).
          </p>
        </section>

        <section class="legal-section" id="t2">
          <h2>2. Description of Service</h2>
          <p>
            Submindo is a personal subscription tracking and management application that allows you to:
          </p>
          <ul>
            <li>Track recurring subscription services, costs, and billing cycles</li>
            <li>Set reminders for upcoming billing dates</li>
            <li>View spending summaries and analytics</li>
            <li>Receive AI-powered analysis of your subscription portfolio</li>
            <li>Discover alternative subscription options at lower costs</li>
          </ul>
          <p>
            Submindo is a personal finance tool for informational purposes only. It does not provide financial advice,
            make payments on your behalf, or access any of your financial accounts.
          </p>
        </section>

        <section class="legal-section" id="t3">
          <h2>3. Eligibility</h2>
          <p>
            You must be at least 13 years of age to use Submindo. By using the App, you represent and warrant
            that you meet this age requirement. If you are under 18, you represent that you have parental
            or guardian consent to use the App.
          </p>
        </section>

        <section class="legal-section" id="t4">
          <h2>4. User Content and Data</h2>
          <h3>4.1 Your Data</h3>
          <p>
            All subscription information you enter into Submindo ("Your Data") remains yours. You retain full
            ownership of and responsibility for Your Data. By using the App, you grant KomKat Studio a limited,
            non-exclusive license to process Your Data solely as necessary to provide the App's features.
          </p>

          <h3>4.2 Accuracy</h3>
          <p>
            You are responsible for the accuracy of the information you enter into Submindo. The App's
            analysis, reminders, and summaries are based entirely on the data you provide — if the data is
            wrong, the outputs will be wrong. Submindo is not liable for decisions made based on inaccurate
            user-entered data.
          </p>

          <h3>4.3 AI-Generated Content</h3>
          <p>
            Submindo uses AI to generate spending analysis, efficiency scores, and alternative plan recommendations.
            This content is automatically generated and may contain errors or inaccuracies. AI-generated
            recommendations do not constitute financial, legal, or professional advice.
            Always independently verify before making purchasing decisions.
          </p>
        </section>

        <section class="legal-section" id="t5">
          <h2>5. Acceptable Use</h2>
          <p>You agree not to:</p>
          <ul>
            <li>Use the App for any unlawful purpose or in violation of any applicable laws</li>
            <li>Attempt to reverse-engineer, decompile, or disassemble the App</li>
            <li>Use automated means to access or scrape any portion of the App or its services</li>
            <li>Misuse the AI features to generate harmful, offensive, or misleading content</li>
            <li>Circumvent any security measures in the App</li>
            <li>Impersonate KomKat Studio or any other person or entity</li>
          </ul>
        </section>

        <section class="legal-section" id="t6">
          <h2>6. Subscriptions and Payments</h2>
          <p>
            Submindo may offer a free tier and optional paid features or subscriptions. If paid features are
            available:
          </p>
          <ul>
            <li>Prices are displayed in the App and subject to change with notice</li>
            <li>Purchases are processed through Apple App Store or Google Play Store</li>
            <li>Refunds are governed by Apple's or Google's refund policies, not KomKat Studio</li>
            <li>Subscriptions auto-renew unless cancelled at least 24 hours before the renewal date</li>
          </ul>
        </section>

        <section class="legal-section" id="t7">
          <h2>7. Intellectual Property</h2>
          <p>
            Submindo, including its design, code, graphics, AI models, brand name, and all associated
            intellectual property, are owned by KomKat Studio and protected by applicable intellectual
            property laws.
          </p>
          <p>
            You are granted a personal, non-transferable, non-exclusive license to use the App on devices
            you own or control, in accordance with these Terms. This license does not include any right to
            copy, modify, distribute, sell, or sublicense the App.
          </p>
        </section>

        <section class="legal-section" id="t8">
          <h2>8. Disclaimers</h2>
          <p>
            THE APP IS PROVIDED "AS IS" AND "AS AVAILABLE" WITHOUT WARRANTIES OF ANY KIND, EITHER EXPRESS OR
            IMPLIED, INCLUDING BUT NOT LIMITED TO WARRANTIES OF MERCHANTABILITY, FITNESS FOR A PARTICULAR PURPOSE,
            OR NON-INFRINGEMENT.
          </p>
          <p>
            KomKat Studio does not warrant that:
          </p>
          <ul>
            <li>The App will be uninterrupted, error-free, or secure</li>
            <li>Any AI-generated analysis or recommendations will be accurate or complete</li>
            <li>Reminder notifications will be delivered in all circumstances (e.g., due to device restrictions)</li>
            <li>Third-party subscription pricing information will be current or accurate</li>
          </ul>
        </section>

        <section class="legal-section" id="t9">
          <h2>9. Limitation of Liability</h2>
          <p>
            TO THE MAXIMUM EXTENT PERMITTED BY LAW, KOMKAT STUDIO SHALL NOT BE LIABLE FOR ANY INDIRECT,
            INCIDENTAL, SPECIAL, CONSEQUENTIAL, OR PUNITIVE DAMAGES ARISING FROM YOUR USE OF OR INABILITY
            TO USE THE APP, INCLUDING BUT NOT LIMITED TO:
          </p>
          <ul>
            <li>Missed billing reminders or unexpected charges to your accounts</li>
            <li>Financial decisions made based on AI-generated recommendations</li>
            <li>Loss of data due to device failure or app errors</li>
            <li>Any third-party service issues</li>
          </ul>
          <p>
            In jurisdictions that do not allow limitation of liability, our liability is limited to the
            maximum extent permitted by law, and in no event shall it exceed the amount you paid to us
            in the 12 months preceding the claim.
          </p>
        </section>

        <section class="legal-section" id="t10">
          <h2>10. Third-Party Services</h2>
          <p>
            Submindo integrates with third-party services (AI providers, app stores, analytics). Your use
            of these services through Submindo is governed by their respective terms of service and privacy
            policies. KomKat Studio is not responsible for the actions or content of third-party services.
          </p>
        </section>

        <section class="legal-section" id="t11">
          <h2>11. Termination</h2>
          <p>
            You may stop using Submindo at any time by uninstalling the App. KomKat Studio reserves the
            right to suspend or terminate access to the App for users who violate these Terms, without
            prior notice.
          </p>
        </section>

        <section class="legal-section" id="t12">
          <h2>12. Changes to Terms</h2>
          <p>
            We may update these Terms from time to time. We will notify you of significant changes via
            in-app notice or by updating the "Effective Date" above. Continued use of Submindo after
            changes take effect constitutes acceptance of the revised Terms.
          </p>
        </section>

        <section class="legal-section" id="t13">
          <h2>13. Governing Law</h2>
          <p>
            These Terms are governed by the laws applicable in the jurisdiction where KomKat Studio is
            registered, without regard to conflict of law principles. Any disputes shall be resolved in
            the courts of that jurisdiction, unless otherwise required by applicable consumer protection laws
            in your location.
          </p>
        </section>

        <section class="legal-section" id="t14">
          <h2>14. Contact</h2>
          <p>Questions about these Terms of Service?</p>
          <div class="legal-contact neo-card-surface">
            <strong>KomKat Studio</strong><br />
            Email: <a href="mailto:komkat.studio@gmail.com">komkat.studio@gmail.com</a>
          </div>
        </section>
      </div>
      </div> <!-- /legal-layout -->
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .legal-page { padding: var(--sp-12) 0 var(--sp-24); }

  .legal-header { margin-bottom: var(--sp-8); }
  .back-link { display: inline-flex; margin-bottom: var(--sp-6); }
  .legal-title-row {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    margin-bottom: var(--sp-2);
    flex-wrap: wrap;
  }
  .legal-title {
    font-family: var(--font-display);
    font-size: var(--text-display1);
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1.1;
  }
  .legal-meta { font-size: var(--text-body2); color: var(--text-secondary); }

  .legal-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--sp-8);
    align-items: start;
  }

  .legal-toc {
    position: sticky;
    top: calc(var(--nav-h) + var(--sp-6));
    padding: var(--sp-5);
  }
  .toc-heading {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: var(--sp-4);
  }
  .toc-list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    list-style: none;
  }
  .toc-list a {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 500;
    color: var(--text-secondary);
    line-height: 1.4;
    transition: color 120ms;
    display: block;
    padding: 3px var(--sp-3);
    border-left: 2px solid transparent;
  }
  .toc-list a:hover { color: var(--primary); border-left-color: var(--primary); }

  .legal-body { width: 100%; }

  .legal-section {
    padding-bottom: var(--sp-8);
    margin-bottom: var(--sp-8);
    border-bottom: 1px solid var(--surface);
  }
  .legal-section:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }

  .legal-section h2 {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--sp-4);
  }
  .legal-section h3 {
    font-family: var(--font-display);
    font-size: var(--text-title1);
    font-weight: 600;
    color: var(--text-primary);
    margin: var(--sp-5) 0 var(--sp-3);
  }
  .legal-section p {
    font-size: var(--text-body1);
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: var(--sp-4);
  }
  .legal-section p:last-child { margin-bottom: 0; }
  .legal-section ul {
    list-style: disc;
    padding-left: var(--sp-6);
    margin-bottom: var(--sp-4);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .legal-section li { font-size: var(--text-body1); color: var(--text-secondary); line-height: 1.6; }
  .legal-section a { color: var(--primary); text-decoration: underline; }

  .legal-contact {
    margin-top: var(--sp-4);
    padding: var(--sp-5);
    font-size: var(--text-body1);
    line-height: 1.8;
  }
  .legal-contact strong { color: var(--text-primary); }
  .legal-contact a { color: var(--primary); text-decoration: underline; }

  .toc-list a.active {
    color: var(--primary);
    border-left-color: var(--primary);
    font-weight: 700;
    background: var(--primary-light, #EEF0FE);
    border-radius: 0 4px 4px 0;
  }

  @media (max-width: 768px) {
    .legal-layout { grid-template-columns: 1fr; }
    .legal-toc { position: static; }
  }
</style>

<script>
  const sections = document.querySelectorAll<HTMLElement>('section[id]');
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-list a');

  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        tocLinks.forEach(link => {
          link.classList.remove('active');
          if (link.getAttribute('href') === '#' + entry.target.id) {
            link.classList.add('active');
          }
        });
      }
    });
  }, { rootMargin: '-10% 0px -75% 0px', threshold: 0 });

  sections.forEach(s => observer.observe(s));
</script>
