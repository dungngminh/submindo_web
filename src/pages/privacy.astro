---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const effectiveDate = 'May 9, 2026';
---

<Layout
  title="Privacy Policy — Submindo"
  description="How Submindo collects, uses, and protects your information."
>
  <Navbar />
  <main class="legal-page">
    <div class="container">
      <div class="legal-header">
        <a href="/" class="back-link btn btn-surface btn-sm">← Back to Home</a>
        <div class="legal-title-row">
          <h1 class="legal-title">Privacy Policy</h1>
          <span class="badge badge-dark">Legal</span>
        </div>
        <p class="legal-meta">Effective Date: <strong>{effectiveDate}</strong> &nbsp;·&nbsp; KomKat Studio</p>
      </div>

      <div class="legal-layout">
        <!-- TOC sidebar -->
        <aside class="legal-toc neo-card-surface">
          <p class="toc-heading">Contents</p>
          <nav>
            <ol class="toc-list">
              <li><a href="#s1">1. Overview</a></li>
              <li><a href="#s2">2. Information We Collect</a></li>
              <li><a href="#s3">3. How We Use Your Information</a></li>
              <li><a href="#s4">4. Data Storage &amp; Security</a></li>
              <li><a href="#s5">5. Third-Party Services</a></li>
              <li><a href="#s6">6. Push Notifications</a></li>
              <li><a href="#s7">7. Children's Privacy</a></li>
              <li><a href="#s8">8. Your Rights</a></li>
              <li><a href="#s9">9. Changes to Policy</a></li>
              <li><a href="#s10">10. Contact Us</a></li>
            </ol>
          </nav>
        </aside>

      <div class="legal-body neo-card">
        <section class="legal-section" id="s1">
          <h2>1. Overview</h2>
          <p>
            Submindo ("the App", "we", "us", or "our") is operated by KomKat Studio. We are committed to protecting your privacy.
            This Privacy Policy explains what information we collect, how we use it, and your rights regarding that information.
          </p>
          <p>
            <strong>Short version:</strong> Submindo is a local-first app. Your subscription data lives on your device.
            We do not sell your data, show ads, or require you to create an account.
          </p>
        </section>

        <section class="legal-section" id="s2">
          <h2>2. Information We Collect</h2>
          <h3>2.1 Data You Provide</h3>
          <p>When you use Submindo, you may enter the following information voluntarily:</p>
          <ul>
            <li>Subscription names, prices, billing cycles, and start dates</li>
            <li>Custom subscription categories and types</li>
            <li>Reminder preferences (days before billing)</li>
            <li>Notes or labels you add to subscriptions</li>
          </ul>
          <p>
            This data is stored locally on your device using the device's local database. It is not transmitted to our servers
            unless you explicitly use a backup or sync feature (if available).
          </p>

          <h3>2.2 Automatically Collected Information</h3>
          <p>We may collect limited technical information to improve the App's performance and stability, including:</p>
          <ul>
            <li>Device type, operating system version</li>
            <li>App version and crash reports (via platform-native crash reporting)</li>
            <li>General usage analytics (e.g., which features are used, session length) — anonymized and aggregated</li>
          </ul>
          <p>This information does not identify you personally and cannot be linked back to your subscription data.</p>

          <h3>2.3 AI Features</h3>
          <p>
            Submindo's AI spending analysis and alternatives finder may send anonymized subscription metadata
            (e.g., service category, price range, billing cycle) to an AI processing service to generate insights.
            This data does not include your name, email, or any personally identifying information.
            Responses are processed and discarded — we do not store your AI query history on our servers.
          </p>
        </section>

        <section class="legal-section" id="s3">
          <h2>3. How We Use Your Information</h2>
          <p>We use the information described above to:</p>
          <ul>
            <li>Provide core subscription tracking and reminder functionality</li>
            <li>Generate AI spending analysis and alternative plan recommendations</li>
            <li>Send local push notifications for upcoming billing dates (if you grant permission)</li>
            <li>Improve app performance, fix bugs, and develop new features</li>
            <li>Analyze aggregate, anonymized usage patterns to understand how the App is used</li>
          </ul>
          <p>We do <strong>not</strong> use your data to:</p>
          <ul>
            <li>Serve advertisements</li>
            <li>Build profiles for third-party marketing</li>
            <li>Sell or rent your data to third parties</li>
          </ul>
        </section>

        <section class="legal-section" id="s4">
          <h2>4. Data Storage and Security</h2>
          <p>
            Your subscription data is stored locally on your device using the device's built-in secure storage.
            We apply industry-standard security practices including encryption at rest (where supported by the platform)
            and secure HTTPS connections for any network communications.
          </p>
          <p>
            No system is 100% secure. We encourage you to keep your device's OS up to date and use a strong device passcode.
          </p>
        </section>

        <section class="legal-section" id="s5">
          <h2>5. Third-Party Services</h2>
          <p>The App may integrate with the following third-party services:</p>
          <ul>
            <li>
              <strong>AI Processing (OpenAI / similar):</strong> Used to power spending analysis and alternatives finding.
              Anonymized, non-identifying subscription metadata may be sent. See OpenAI's Privacy Policy for their data practices.
            </li>
            <li>
              <strong>Platform Crash Reporting (Firebase Crashlytics / Sentry):</strong> Anonymized crash data to help us fix bugs.
            </li>
            <li>
              <strong>App Stores (Apple App Store / Google Play):</strong> Governed by Apple's and Google's respective privacy policies.
            </li>
          </ul>
          <p>We do not share personally identifiable information with any third party beyond what is described here.</p>
        </section>

        <section class="legal-section" id="s6">
          <h2>6. Push Notifications</h2>
          <p>
            Submindo requests permission to send push notifications to remind you of upcoming billing dates.
            Notifications are generated locally on your device based on the data you enter. You can disable
            notifications at any time via your device's system settings.
          </p>
        </section>

        <section class="legal-section" id="s7">
          <h2>7. Children's Privacy</h2>
          <p>
            Submindo is not directed at children under 13 years of age. We do not knowingly collect personal
            information from children under 13. If you believe we have inadvertently collected such information,
            please contact us and we will promptly delete it.
          </p>
        </section>

        <section class="legal-section" id="s8">
          <h2>8. Your Rights</h2>
          <p>Depending on your location, you may have rights regarding your personal data, including:</p>
          <ul>
            <li><strong>Access:</strong> Request a copy of data we hold about you</li>
            <li><strong>Deletion:</strong> Request deletion of your data (for locally stored data, simply uninstall the App)</li>
            <li><strong>Correction:</strong> Update or correct inaccurate data (done directly within the App)</li>
            <li><strong>Portability:</strong> Export your subscription data (if the App supports export features)</li>
            <li><strong>Opt-out:</strong> Disable analytics data collection via your device settings or by contacting us</li>
          </ul>
          <p>To exercise any of these rights, contact us at <a href="mailto:komkat.studio@gmail.com">komkat.studio@gmail.com</a>.</p>
        </section>

        <section class="legal-section" id="s9">
          <h2>9. Changes to This Policy</h2>
          <p>
            We may update this Privacy Policy from time to time. When we do, we will update the "Effective Date"
            at the top of this page and, for significant changes, notify you via in-app notice.
            Continued use of Submindo after changes constitutes your acceptance of the updated policy.
          </p>
        </section>

        <section class="legal-section" id="s10">
          <h2>10. Contact Us</h2>
          <p>Questions, concerns, or requests regarding this Privacy Policy?</p>
          <div class="legal-contact neo-card-surface">
            <strong>KomKat Studio</strong><br />
            Email: <a href="mailto:komkat.studio@gmail.com">komkat.studio@gmail.com</a>
          </div>
        </section>
      </div>
      </div> <!-- /legal-layout -->
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .legal-page { padding: var(--sp-12) 0 var(--sp-24); }

  /* Header */
  .legal-header { margin-bottom: var(--sp-8); }
  .back-link { display: inline-flex; margin-bottom: var(--sp-6); }
  .legal-title-row {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    margin-bottom: var(--sp-2);
    flex-wrap: wrap;
  }
  .legal-title {
    font-family: var(--font-display);
    font-size: var(--text-display1);
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1.1;
  }
  .legal-meta { font-size: var(--text-body2); color: var(--text-secondary); }

  /* 2-column layout */
  .legal-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--sp-8);
    align-items: start;
  }

  /* TOC sidebar */
  .legal-toc {
    position: sticky;
    top: calc(var(--nav-h) + var(--sp-6));
    padding: var(--sp-5);
  }
  .toc-heading {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: var(--sp-4);
  }
  .toc-list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    list-style: none;
    counter-reset: none;
  }
  .toc-list a {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 500;
    color: var(--text-secondary);
    line-height: 1.4;
    transition: color 120ms;
    display: block;
    padding: 3px 0;
    border-left: 2px solid transparent;
    padding-left: var(--sp-3);
  }
  .toc-list a:hover { color: var(--primary); border-left-color: var(--primary); }

  .legal-body { width: 100%; }

  .legal-section {
    padding-bottom: var(--sp-8);
    margin-bottom: var(--sp-8);
    border-bottom: 1px solid var(--surface);
  }
  .legal-section:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }

  .legal-section h2 {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--sp-4);
  }
  .legal-section h3 {
    font-family: var(--font-display);
    font-size: var(--text-title1);
    font-weight: 600;
    color: var(--text-primary);
    margin: var(--sp-5) 0 var(--sp-3);
  }
  .legal-section p {
    font-size: var(--text-body1);
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: var(--sp-4);
  }
  .legal-section p:last-child { margin-bottom: 0; }
  .legal-section ul {
    list-style: disc;
    padding-left: var(--sp-6);
    margin-bottom: var(--sp-4);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .legal-section li { font-size: var(--text-body1); color: var(--text-secondary); line-height: 1.6; }
  .legal-section a { color: var(--primary); text-decoration: underline; }

  .legal-contact {
    margin-top: var(--sp-4);
    padding: var(--sp-5);
    font-size: var(--text-body1);
    line-height: 1.8;
  }
  .legal-contact strong { color: var(--text-primary); }
  .legal-contact a { color: var(--primary); text-decoration: underline; }

  .toc-list a.active {
    color: var(--primary);
    border-left-color: var(--primary);
    font-weight: 700;
    background: var(--primary-light, #EEF0FE);
    border-radius: 0 4px 4px 0;
  }

  @media (max-width: 768px) {
    .legal-layout { grid-template-columns: 1fr; }
    .legal-toc { position: static; }
  }
</style>

<script>
  const sections = document.querySelectorAll<HTMLElement>('section[id]');
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-list a');

  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        tocLinks.forEach(link => {
          link.classList.remove('active');
          if (link.getAttribute('href') === '#' + entry.target.id) {
            link.classList.add('active');
          }
        });
      }
    });
  }, { rootMargin: '-10% 0px -75% 0px', threshold: 0 });

  sections.forEach(s => observer.observe(s));
</script>
